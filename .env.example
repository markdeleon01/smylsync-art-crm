# https://vercel.com/docs/storage/vercel-postgres
POSTGRES_URL=

BCRYPT_SALT_ROUNDS=12
BCRYPT_PEPPER=
JWT_SECRET=

# Nodemailer SMTP (leave blank to disable email sending, e.g. in CI)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Clinic hours shown on the Schedules page and used for slot availability.
# Format: HH:MM-HH:MM or "closed"
CLINIC_HOURS_MONDAY=08:00-20:00
CLINIC_HOURS_TUESDAY=08:00-20:00
CLINIC_HOURS_WEDNESDAY=08:00-20:00
CLINIC_HOURS_THURSDAY=08:00-20:00
CLINIC_HOURS_FRIDAY=08:00-20:00
CLINIC_HOURS_SATURDAY=08:00-20:00
CLINIC_HOURS_SUNDAY=08:00-20:00

# Secret token used to authenticate the hourly reminder cron job
CRON_SECRET=

# API key for the HTTP MCP server endpoint (/api/[transport])
MCP_API_KEY=

SESSION_EXPIRY=8h   # hours  (default)
#SESSION_EXPIRY=30m  # minutes
#SESSION_EXPIRY=1d   # days
#SESSION_EXPIRY=3600s # seconds
