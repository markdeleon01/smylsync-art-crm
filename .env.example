# https://vercel.com/docs/storage/vercel-postgres
POSTGRES_URL=

NEXTAUTH_URL=http://localhost:8080
AUTH_SECRET= # https://generate-secret.vercel.app/32

# https://authjs.dev/getting-started/providers/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

BCRYPT_SALT_ROUNDS=12
BCRYPT_PEPPER=
JWT_SECRET=

# Nodemailer SMTP (leave blank to disable email sending, e.g. in CI)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Secret token used to authenticate the hourly reminder cron job
CRON_SECRET=

SESSION_EXPIRY=8h   # hours  (default)
#SESSION_EXPIRY=30m  # minutes
#SESSION_EXPIRY=1d   # days
#SESSION_EXPIRY=3600s # seconds